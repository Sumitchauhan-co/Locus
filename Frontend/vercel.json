{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://your-backend-url.onrender.com/api/:path*"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/sitemap.xml"
        },
        {
            "source": "/robots.txt",
            "destination": "/robots.txt"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ]
}